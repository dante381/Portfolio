# =============================================================
# Environment variable placeholders — DO NOT put real values here.
# Copy this file to .env.local and fill in real values locally.
# Set these in Vercel Dashboard for production (never in code).
# =============================================================

# Neon Postgres connection string
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# JWT signing secret — generate with: openssl rand -base64 32
AUTH_SECRET=your-256-bit-secret-here

# Admin dashboard credentials
ADMIN_USERNAME=admin
# Pre-hash password with bcrypt cost 12 before setting this
ADMIN_PASSWORD_HASH=$2b$12$examplehashedpasswordhere

# Daily-rotating salt for visitor_hash (sha256(IP+UA+salt))
# Rotate this value periodically; old hashes become unresolvable (privacy by design)
HASH_SALT=your-random-salt-here

# Upstash Redis — for rate limiting (get from console.upstash.com)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
